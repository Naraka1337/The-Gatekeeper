[sshd]
enabled = true
port    = ssh
filter  = sshd
backend = systemd
maxretry = 3
findtime = 10m
bantime  = 1h
action  = %(action_)s
          %(mta)s[name=SSH, dest=root]
          iptables-multiport[name=SSH, port="ssh", protocol=tcp]
          shell[actionstart="", actionstop="", actionban="/usr/local/bin/telegram-alert.sh <ip>"]
